// Union literal syntax (spec §Types > Union Type)

union Value{
    as_i32: i32,
    as_f32: f32,
    as_bytes: [4]u8,
}

func test_union_literal(){
    // Variant-like union literal (named field)
    var v1 = Value::as_i32(12345);

    // Struct-like union literal (zero-initialized)
    var v2 = Value{};

    // Field assignment
    v1.as_f32 = 1.0;
    v1.as_i32 = 1;
    v1.as_bytes = [4]u8{2, 5, 6, 8};
}
