// Ternary conditional operator ?: (spec §Operators, precedence 1)

// Nested ternary (right-associative)
func nested_ternary(a: i32, b: i32, c: i32):i32{
    return a > b ? (a > c ? a : c) : (b > c ? b : c);
}

// Ternary in assignment
func ternary_assign(flag: bool):i32{
    var result = flag ? 100 : 200;
    return result;
}

// Ternary as part of expression
func ternary_expr(x: i32, y: i32):i32{
    return (x > y ? x : y) + 10;
}

// Ternary with function calls
func sign(x: i32):i32{
    return x > 0 ? 1 : (x < 0 ? -1 : 0);
}
