func for_infinite(){
    var count = 0;
    while{
        count += 1;
        if count >= 10 {
            break;
        }
    }
}

func for_cond(){
    var i = 0;
    while i < 10 {
        i += 1;
    }
}

func for_cstyle_0(){
    for var i = 0; i < 10; i += 1 {
        if i == 5 {
            continue;
        }
    }
}

func for_cstyle_2(){
    var i = 0;
    for ; i < 10; i += 1 {
        if i == 5 {
            continue;
        }
    }
}

func for_cstyle_3(){
    for var i = 0; ; i += 1 {
        if i >= 0 { break; }
    }
}

func for_cstyle_4(){
    for var i = 0; i < 10;  {
        if i == 5 {
            continue;
        }
        i += 1;
    }
}

func for_cstyle_5(){
    var i = 0;
    for ; ; i += 1 {
        break;
    }
}

func for_cstyle_6(){
    var i = 0;
    for ; i < 10; {
         i += 1;
    }
}

func for_cstyle_7(){
    for var i = 0; ;  {
        if i >= 10 {
            break;
        }
        i += 1;
    }
}

func for_cstyle_8(){
    var i = 0;
    for ;; {
        if  i < 10 {break;}
        i+=1;
    }
}