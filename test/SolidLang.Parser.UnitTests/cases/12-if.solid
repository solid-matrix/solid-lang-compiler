func if_basic(n: i32):i32{
    if n > 0 {
        return 1;
    }
    return 0;
}

func if_else(n: i32):i32{
    if n > 0 {
        return 1;
    }else{
        return 2;
    }
}

func if_else_if(n: i32):i32{
    if n > 0 {
        return 1;
    }else if n < 0{
        return -1;
    }
    return 0;
}

func if_else_if_else(x: i32):i32{
    if x > 0 {
        return 1;
    } else if x == 0 {
        return 0;
    } else{
        return -1;
    }
}

func nested_if(a: i32, b: i32):bool{
    if a > 0 {
        if b > 0 {
            return true;
        }
    }
    return false;
}