// Float literal forms
// NOTE: .5 (dot-prefix) float literals are not yet supported by the parser

func float_regular(){
    var a = 1.5;
    var b = 0.5;
    var c = 3.14159;
}

func float_scientific(){
    var a = 1e10;
    var b = 1.5e-3;
    var c = 2.0E+4;
}

func float_suffixes(){
    var a: f32 = 1.5f32;
    var b: f64 = 1.5f64;
    var d: f64 = 1e10f64;
}
